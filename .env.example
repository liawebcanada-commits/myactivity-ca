# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://myactivity.ca

# ─── Analytics ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── AdSense ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ─── AdSense Ad Slot IDs ─────────────────────────────────────────────────────
# City hub pages slot
NEXT_PUBLIC_ADSENSE_SLOT_CITY=0000000000
# Category pages slot
NEXT_PUBLIC_ADSENSE_SLOT_CATEGORY=1111111111

# ─── Affiliate Networks ─────────────────────────────────────────────────────
# GetYourGuide — apply at https://partner.getyourguide.com/
GETYOURGUIDE_AFFILIATE_ID=your-partner-id
# Viator — apply at https://www.partner.viator.com/
VIATOR_AFFILIATE_ID=your-campaign-id
# Groupon Canada
GROUPON_AFFILIATE_ID=your-affiliate-id
# Ticketmaster CA — apply at https://affiliate.ticketmaster.ca/
TICKETMASTER_AFFILIATE_ID=your-affiliate-id

# ─── ISR Revalidation ───────────────────────────────────────────────────────────────────
# Webhook secret for /api/revalidate endpoint
REVALIDATE_SECRET=change-me-to-a-strong-random-string

# ─── Email (Privacy Policy contact) ─────────────────────────────────────────────
CONTACT_EMAIL=contact@liaweb.ca
